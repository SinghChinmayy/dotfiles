#!/usr/bin/env bash
set -euo pipefail

SRC_DIR="$HOME/Pictures/Screenshots"
DEST_DIR="$HOME/Pictures/Screenshots/final-ss"
DEST="$DEST_DIR/latest-ss.png"

mkdir -p "$DEST_DIR"

latest=$(find "$SRC_DIR" -maxdepth 1 -type f \
    \( -iname '*.png' -o -iname '*.jpg' -o -iname '*.jpeg' \) \
    -printf '%T@ %p\n' 2>/dev/null | sort -nr | head -n1 | cut -d' ' -f2-)

if [ -z "$latest" ]; then
    echo "No screenshots found in $SRC_DIR"
    exit 1
fi

cp -f "$latest" "$DEST"
echo "Copied: $latest -> $DEST"
